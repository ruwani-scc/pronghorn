# Test Environment Configuration
# Used during Jest test execution

NODE_ENV=test
PORT=3001

# Test Database (use separate database for tests)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=vacation_plan_test
DB_USER=postgres
DB_PASSWORD=postgres
DB_SSL=false
DB_POOL_MAX=5
DB_POOL_MIN=1

# Test Authentication
JWT_SECRET=test-secret-key-do-not-use-in-production
JWT_EXPIRES_IN=1d

# Disable external services in tests
SENTRY_DSN=
DATADOG_API_KEY=

# Test Configuration
SUPPRESS_TEST_LOGS=true
LOG_LEVEL=silent
LOG_QUERIES=false
