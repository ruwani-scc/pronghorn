# Base URL for the application under test
BASE_URL=http://localhost:3000

# Default test user credentials (for authenticatedPage fixture)
TEST_USER_EMAIL=admin@example.com
TEST_USER_PASSWORD=Admin@123

# Optional: CI/CD environment flag
# CI=true

# Optional: Browser-specific settings
# HEADED=false
# BROWSER=chromium

# Optional: Test execution settings
# WORKERS=4
# RETRIES=2
# TIMEOUT=30000

# Optional: Reporting
# REPORT_PATH=./test-results

# Instructions:
# 1. Copy this file to .env
# 2. Update the values according to your environment
# 3. Never commit .env file to version control
