# E2E Test Environment Configuration

# Application URLs
BASE_URL=http://localhost:5173
API_URL=http://localhost:5000/api/v1

# Test Configuration
TEST_TIMEOUT=30000
HEADLESS=true
SLOW_MO=0

# Browser Configuration
BROWSER=chromium
VIEWPORT_WIDTH=1280
VIEWPORT_HEIGHT=720

# Authentication (for real API testing)
TEST_USER_EMAIL=test@example.com
TEST_USER_PASSWORD=TestPassword123!
AUTH_TOKEN=

# Feature Flags
ENABLE_VIDEO=false
ENABLE_TRACE=on-first-retry
ENABLE_SCREENSHOTS=only-on-failure

# API Mocking
USE_MOCK_API=true
MOCK_API_DELAY=100

# Debugging
DEBUG=false
VERBOSE_LOGGING=false

# CI/CD Configuration
CI=false
RETRIES=0
WORKERS=4

# Reporting
REPORTER=html,json,junit
REPORT_PATH=./playwright-report
